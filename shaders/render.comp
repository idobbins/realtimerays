    uint bounceEmits = 0u;
    uint shadowDir[RTR_BUDGET_MAX];
    float shadowFar[RTR_BUDGET_MAX];
    uint shadowPend[RTR_BUDGET_MAX];
    uint bounceDir[RTR_BUDGET_MAX];
    uint chainThroughput = 0u;

    if (valid) {
        uint w = rtrWfRayWord(pc.parity, index);
        vec3 ro = vec3(rtrLoadF32(w), rtrLoadF32(w + 1u), rtrLoadF32(w + 2u));
        vec3 rd = rtrUnpackDirection(rtrLoadU32(w + 3u));
        uint hitWord = rtrLoadU32(rtrWfHitWord(index));
        f16vec3 throughput = f16vec3(rtrUnpackRgb9e5(rtrLoadU32(w + 4u)));

        pixel = rtrLoadU32(w + 5u);

        if ((hitWord & 0x80000000u) == 0u) {
            f16vec3 skyContribution = throughput * rtrSky(rd);

            if (pc.depth > 0u)
                skyContribution =
                    rtrClampLuminance(skyContribution,
                                      float16_t(RTR_INDIRECT_LUMINANCE_CAP));
            rtrWfAccumAdd(pixel, skyContribution);
        } else {
            float t = uintBitsToFloat(rtrLoadU32(rtrWfHitWord(index) + 1u));
            uint axis = (hitWord >> 24u) & 3u;
            ivec3 voxel = ivec3(int(hitWord & 255u),
                                int((hitWord >> 8u) & 255u),
                                int((hitWord >> 16u) & 255u));
            vec3 hitP = ro + rd * t;
            vec3 n = rtrHitNormal(axis, rd);
            f16vec3 albedo = rtrVoxelAlbedo(voxel, hitP, n);
            uint hashLight = rtrHashPosition(hitP, n);
            uint hashHemi = rtrHashU32(hashLight);
            uint sampleSalt = rtrWfSampleSalt();
            vec2 ham = rtrSampleHam(pc.sampleIndex);
            uint blueTile = 0u;

            if (pc.depth == 0u && shSpp == 1u) {
                uint pixelY = pixel / uint(shSize.x);
                uint pixelX = pixel - pixelY * uint(shSize.x);

                blueTile = ((pixelX + shFrameSalt) & 127u) +
                    ((pixelY + (shFrameSalt >> 16u)) & 127u) * 128u;
            }

            /* Direct light: at the first hit the budget splits the light
             * estimator into several cheap shadow rays, each weighted
             * 1/K; deeper hits keep one sample. */
            uint lightSamples = pc.depth == 0u ? shLightSpp : 1u;
            f16vec3 directBase = throughput * albedo *
                f16vec3(float16_t(1.0 / float(lightSamples)));
            vec2 uLBase;
            if (pc.depth == 0u) {
                uLBase = shSpp == 1u ? rtrBlueNoise4(blueTile, 0u).xy :
                    fract(ham + rtrHashToUnit2(hashLight) + shFrameRot);
            } else {
                uLBase = rtrHashToUnit2(rtrHashU32(hashLight ^ sampleSalt));
            }

            for (uint i = 0u; i < lightSamples; i++) {
                vec2 uL = i == 0u ?
                    uLBase : fract(uLBase + rtrBudgetShift(i));
                vec3 l;
                float lightT;
                float lightScale;

                if (!rtrSampleLight(hitP, n, uL, l, lightT, lightScale))
                    continue;

                f16vec3 pending = directBase *
                    f16vec3(RTR_LIGHT_COLOR * lightScale);

                if (pc.depth > 0u)
                    pending = rtrClampLuminance(
                        pending, float16_t(RTR_INDIRECT_LUMINANCE_CAP));
                shadowDir[shadowEmits] = rtrPackDirection(l);
                shadowFar[shadowEmits] = lightT - RTR_EPS * 8.0;
                shadowPend[shadowEmits] = rtrPackRgb9e5(vec3(pending));
                shadowEmits++;
            }

            /* Indirect: the first hit branches into M chains carrying
             * throughput/M each (unbiased splitting); deeper hits
             * continue a single chain. */
            uint giChains = pc.depth + 1u < RTR_PATH_BOUNCES ?
                (pc.depth == 0u ? shGiSpp : 1u) : 0u;

            if (giChains > 0u) {
                vec4 blueH = pc.depth == 0u && shSpp == 1u ?
                    rtrBlueNoise4(blueTile, 1u) : vec4(0.0);
                vec2 uHBase;

                if (pc.depth == 0u) {
                    uHBase = shSpp == 1u ? blueH.xy :
                        fract(ham + rtrHashToUnit2(hashHemi) * hemiJitter +
                              shFrameRot);
                } else {
                    uHBase =
                        rtrHashToUnit2(rtrHashU32(hashHemi ^ sampleSalt));
                }

                chainThroughput =
                    rtrPackRgb9e5(vec3(throughput * albedo) /
                                  float(giChains));
                for (uint j = 0u; j < giChains; j++) {
                    vec2 uH = pc.depth == 0u && shSpp == 1u && j == 1u ?
                        blueH.zw :
                        (j == 0u ? uHBase :
                         fract(uHBase + rtrBudgetShift(j)));

                    bounceDir[bounceEmits] =
                        rtrPackDirection(rtrCosineHemisphere(n, uH));
                    bounceEmits++;
                }
            }
            emitRo = hitP + n * RTR_EPS * 8.0;
        }
    }

    uint shadowLocal = 0u;
    uint bounceLocal = 0u;

    if (shadowEmits > 0u)
        shadowLocal = atomicAdd(shWfShadowCount, shadowEmits);
    if (bounceEmits > 0u)
        bounceLocal = atomicAdd(shWfOutCount, bounceEmits);

    barrier();

    if (gl_LocalInvocationIndex == 0u) {
        shWfShadowBase = atomicAdd(rtrMem[RTR_WF_SHADOW_COUNT_WORD +
                                          pc.parity],
                                   shWfShadowCount);
        shWfOutBase = atomicAdd(rtrMem[RTR_WF_RAY_COUNT_WORD +
                                       (pc.parity ^ 1u)],
                                shWfOutCount);
    }

    barrier();

    for (uint i = 0u; i < shadowEmits; i++) {
        uint w = rtrWfShadowWord(pc.parity,
                                 shWfShadowBase + shadowLocal + i);

        rtrStoreF32(w, emitRo.x);
        rtrStoreF32(w + 1u, emitRo.y);
        rtrStoreF32(w + 2u, emitRo.z);
        rtrStoreU32(w + 3u, shadowDir[i]);
        rtrStoreF32(w + 4u, shadowFar[i]);
        rtrStoreU32(w + 5u, shadowPend[i]);
        rtrStoreU32(w + 6u, pixel);
    }
    for (uint j = 0u; j < bounceEmits; j++) {
        uint w = rtrWfRayWord(pc.parity ^ 1u,
                              shWfOutBase + bounceLocal + j);

        rtrStoreF32(w, emitRo.x);
        rtrStoreF32(w + 1u, emitRo.y);
        rtrStoreF32(w + 2u, emitRo.z);
        rtrStoreU32(w + 3u, bounceDir[j]);
        rtrStoreU32(w + 4u, chainThroughput);
        rtrStoreU32(w + 5u, pixel);
    }
}

#elif RTR_RENDER_PASS == 4

void main()
{
    uint index = gl_GlobalInvocationID.x;
    uint count = rtrLoadU32(RTR_WF_SHADOW_COUNT_WORD + pc.parity);

    /* Group-uniform exit: fully dead workgroups skip the shared init. */
    if (gl_WorkGroupID.x * gl_WorkGroupSize.x >= count)
        return;

    if (gl_LocalInvocationIndex == 0u)
        rtrInitShared();

    barrier();

    if (index >= count)
        return;

    uint w = rtrWfShadowWord(pc.parity, index);
    vec3 ro = vec3(rtrLoadF32(w), rtrLoadF32(w + 1u), rtrLoadF32(w + 2u));
    vec3 rd = rtrUnpackDirection(rtrLoadU32(w + 3u));
    float maxT = rtrLoadF32(w + 4u);
    RTRVoxelHit blocker;

    if (!rtrTraceVoxels(ro, rd, maxT, RTR_STAT_CLASS_SHADOW, blocker)) {
        f16vec3 pendingDirect = f16vec3(rtrUnpackRgb9e5(rtrLoadU32(w + 5u)));

        rtrWfAccumAdd(rtrLoadU32(w + 6u), pendingDirect);
    }
}

#elif RTR_RENDER_PASS == 5

void main()
{
    ivec2 p = ivec2(gl_GlobalInvocationID.xy);

    if (gl_LocalInvocationIndex == 0u)
        rtrInitShared();

    barrier();

    if (any(greaterThanEqual(p, shSize)))
        return;

    uint w = rtrWfAccumWord(uint(p.y) * uint(shSize.x) + uint(p.x));
    vec3 color = vec3(float(rtrLoadU32(w)),
                      float(rtrLoadU32(w + 1u)),
                      float(rtrLoadU32(w + 2u))) *
        (1.0 / (65536.0 * float(shSpp)));

    imageStore(rtrOutImage, p, vec4(rtrTonemap(color), 1.0));
}

#endif
